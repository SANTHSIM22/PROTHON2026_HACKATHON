{
  "manifest_version": 3,
  "name": "Audio Recorder Pro",
  "version": "1.1.0",
  "description": "Record your voice AND meeting audio from Google Meet, Zoom, Teams, and any browser audio source.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "tabCapture",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Audio Recorder Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}