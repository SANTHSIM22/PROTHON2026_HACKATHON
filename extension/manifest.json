{
  "manifest_version": 3,
  "name": "Prothon Hackathon Extension",
  "version": "1.0",
  "description": "Chrome extension for technical and non-technical users",
  "icons": {
    "16": "hero.png",
    "48": "hero.png",
    "128": "hero.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "hero.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "offscreen",
    "activeTab"
  ],
  "host_permissions": [
    "https://prothon2026-hackathon.onrender.com/*"
  ]
}